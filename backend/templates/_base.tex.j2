<# Минимальный плейсхолдер — полноценные шаблоны в Этапе 2. #>
\documentclass[a4paper,10pt]{article}
\usepackage{fontspec}
\usepackage[a4paper,margin=18mm]{geometry}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\setmainfont{DejaVu Sans}
\pagestyle{empty}
\setlist[itemize]{leftmargin=*,itemsep=2pt,topsep=2pt}

\begin{document}

{\Large\bfseries << name | tex >>}\par
{\itshape << headline | tex >>}\par
<% if salary_expectation %>
{\small << salary_label | tex >>: << salary_expectation | tex >>}\par
<% endif %>
<% if contacts %>
{\small << contacts | join(' \\textbullet{} ') | tex >>}\par
<% endif %>
\bigskip

<% if summary %>
\textbf{<< labels.summary | tex >>}\par
<< summary | tex >>\par\smallskip
<% endif %>

<% if experience %>
\textbf{<< labels.experience | tex >>}\par
<% for e in experience %>
\textbf{<< e.title | tex >>}<% if e.subtitle %> \textbullet{} << e.subtitle | tex >><% endif %>\hfill << e.period | tex >>\par
<% if e.location %>{\small << e.location | tex >>}\par<% endif %>
<% if e.bullets %>
\begin{itemize}
<% for b in e.bullets %>\item << b | tex >>
<% endfor %>
\end{itemize}
<% endif %>
<% endfor %>
<% endif %>

<% if education %>
\textbf{<< labels.education | tex >>}\par
<% for e in education %>
\textbf{<< e.title | tex >>}<% if e.subtitle %> \textbullet{} << e.subtitle | tex >><% endif %>\hfill << e.period | tex >>\par
<% endfor %>
<% endif %>

<% if skills %>
\textbf{<< labels.skills | tex >>}\par
<% for s in skills %>
<% if s.label %>\textbf{<< s.label | tex >>:} <% endif %><< s.value | tex >>\par
<% endfor %>
<% endif %>

\end{document}
