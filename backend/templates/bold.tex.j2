<# Bold: huge red header bar, sans-serif, tight dense layout. #>
\documentclass[a4paper,10pt]{article}

\usepackage{fontspec}
\usepackage[a4paper,top=0pt,bottom=18mm,left=20mm,right=20mm]{geometry}
\usepackage{xcolor}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage{fontawesome5}
\usepackage[hidelinks]{hyperref}
\usepackage{etoolbox}
\usepackage{tikz}

\setmainfont{DejaVu Sans}[Scale=0.96]
\newfontfamily\heavy{DejaVu Sans}[Scale=1.0]

\definecolor{accent}{HTML}{E11D48}
\definecolor{dark}{HTML}{0F172A}
\definecolor{ink}{HTML}{1E293B}
\definecolor{muted}{HTML}{64748B}
\definecolor{soft}{HTML}{F1F5F9}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\linespread{1.2}

\titleformat{\section}
  {\heavy\bfseries\Large\color{accent}}
  {}{0pt}{}[\vspace{-1pt}\textcolor{accent}{\rule{34pt}{2.4pt}}]
\titlespacing*{\section}{0pt}{14pt}{6pt}

\setlist[itemize]{leftmargin=14pt,itemsep=1.5pt,topsep=2pt,parsep=0pt,label={\textcolor{accent}{\small\faCircle}}}

\begin{document}

% Header band
\noindent\begin{tikzpicture}[remember picture, overlay]
\fill[dark] (current page.north west) rectangle ([yshift=-44mm]current page.north east);
\fill[accent] ([yshift=-44mm]current page.north west) rectangle ([yshift=-47mm]current page.north east);
\end{tikzpicture}
\vspace*{8mm}
\begin{minipage}[t]{\linewidth}
\color{soft}
<% if name %>{\heavy\bfseries\fontsize{32}{34}\selectfont\color{soft}<< name | tex >>}\par<% endif %>
<% if headline %>\vspace{2pt}{\large\color{accent}<< headline | tex >>}\par<% endif %>
\vspace{6pt}
<% if emails or phones or links or other_contacts %>
{\small\color{soft}%
<% set parts = [] %>
<% for e in emails %><% set _ = parts.append('\\faEnvelope~' + (e | tex)) %><% endfor %>
<% for p in phones %><% set _ = parts.append('\\faPhone~' + (p | tex)) %><% endfor %>
<% for l in links %><% set _ = parts.append('\\faGlobe~' + (l | tex)) %><% endfor %>
<% for c in other_contacts %><% set _ = parts.append('\\faMapMarker*~' + (c | tex)) %><% endfor %>
<< parts | join('  \\quad ') >>%
}
<% endif %>
\end{minipage}
\vspace{16mm}

<% if summary %>
\section*{Profile}
{\color{ink}<< summary | tex >>}
<% endif %>

<% if experience %>
\section*{Experience}
<% for e in experience %>
\noindent{\heavy\bfseries\color{dark}<< e.title | tex >>}<% if e.subtitle %>\quad{\color{accent}\rule[2pt]{4pt}{4pt}}\quad{\color{ink}<< e.subtitle | tex >>}<% endif %>\hfill{\small\color{muted}\bfseries << e.period | tex >>}\par
<% if e.location %>{\small\color{muted}\faMapMarker*~<< e.location | tex >>}\par<% endif %>
<% if e.description %>{\small\color{ink}<< e.description | tex >>}\par<% endif %>
<% if e.bullets %>
\begin{itemize}
<% for b in e.bullets %>\item << b | tex >>
<% endfor %>
\end{itemize}
<% endif %>
\vspace{4pt}
<% endfor %>
<% endif %>

<% if projects %>
\section*{Projects}
<% for e in projects %>
\noindent{\bfseries\color{dark}<< e.title | tex >>}<% if e.subtitle %>\quad{\color{muted}<< e.subtitle | tex >>}<% endif %>\hfill{\small\color{muted}<< e.period | tex >>}\par
<% if e.bullets %>
\begin{itemize}
<% for b in e.bullets %>\item << b | tex >>
<% endfor %>
\end{itemize}
<% endif %>
\vspace{4pt}
<% endfor %>
<% endif %>

<% if education %>
\section*{Education}
<% for e in education %>
\noindent{\bfseries\color{dark}<< e.title | tex >>}<% if e.subtitle %>, {\color{muted}<< e.subtitle | tex >>}<% endif %>\hfill{\small\color{muted}\bfseries << e.period | tex >>}\par
<% endfor %>
<% endif %>

<% if skills %>
\section*{Skills}
<% for s in skills %>
\noindent<% if s.label %>{\color{accent}\bfseries\small\MakeUppercase{<< s.label | tex >>}}\quad <% endif %>{\color{ink}<< s.value | tex >>}\par\vspace{3pt}
<% endfor %>
<% endif %>

<% if languages %>
\section*{Languages}
{\color{ink}<< languages | tex >>}
<% endif %>

<% for sec in other_sections %>
\section*{<< sec.title | tex >>}
<% if sec.content %>{\color{ink}<< sec.content | tex >>}<% endif %>
<% if sec.entries %>
<% for e in sec.entries %>
\noindent{\bfseries<< e.title | tex >>}\hfill{\small\color{muted}<< e.period | tex >>}\par
<% if e.bullets %>\begin{itemize}<% for b in e.bullets %>\item << b | tex >><% endfor %>\end{itemize}<% endif %>
<% endfor %>
<% endif %>
<% endfor %>

\end{document}
