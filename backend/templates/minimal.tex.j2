<# Minimal: serif, lots of whitespace, gold hairline accent, centered header. #>
\documentclass[a4paper,11pt]{article}

\usepackage{fontspec}
\usepackage[a4paper,top=28mm,bottom=24mm,left=28mm,right=28mm]{geometry}
\usepackage{xcolor}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{etoolbox}

\setmainfont{DejaVu Serif}[Scale=0.92]
\newfontfamily\sansfont{DejaVu Sans}[Scale=0.85,LetterSpace=4]

\definecolor{gold}{HTML}{B8893A}
\definecolor{ink}{HTML}{1A1A1A}
\definecolor{muted}{HTML}{777777}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\linespread{1.32}

\titleformat{\section}
  {\sansfont\bfseries\small\color{gold}}
  {}{0pt}{\MakeUppercase}
\titlespacing*{\section}{0pt}{18pt}{6pt}

\setlist[itemize]{leftmargin=12pt,itemsep=2pt,topsep=3pt,parsep=0pt,label={\color{gold}\textendash}}

\begin{document}

\begingroup
\centering
<% if name %>{\fontsize{22}{26}\selectfont\color{ink}<< name | tex >>}\par<% endif %>
\vspace{4pt}
{\color{gold}\rule{16pt}{0.6pt}}\par
\vspace{3pt}
<% if headline %>{\sansfont\color{muted}<< headline | tex >>}\par<% endif %>
\vspace{8pt}
<% if contacts %>{\small\color{muted}<< contacts | map('tex') | join('  \\,\\textperiodcentered\\,  ') >>}\par<% endif %>
\endgroup
\vspace{6pt}

<% if summary %>
\section*{Summary}
{\color{ink}<< summary | tex >>}
<% endif %>

<% if experience %>
\section*{Experience}
<% for e in experience %>
{\bfseries\color{ink}<< e.title | tex >>}<% if e.subtitle %>, {\itshape\color{ink}<< e.subtitle | tex >>}<% endif %>\hfill{\sansfont\small\color{muted}<< e.period | tex >>}\par
<% if e.location %>{\small\itshape\color{muted}<< e.location | tex >>}\par<% endif %>
<% if e.description %>{\small\color{ink}<< e.description | tex >>}\par<% endif %>
<% if e.bullets %>
\begin{itemize}
<% for b in e.bullets %>\item << b | tex >>
<% endfor %>
\end{itemize}
<% endif %>
\vspace{4pt}
<% endfor %>
<% endif %>

<% if projects %>
\section*{Projects}
<% for e in projects %>
{\bfseries\color{ink}<< e.title | tex >>}<% if e.subtitle %>, {\itshape << e.subtitle | tex >>}<% endif %>\hfill{\sansfont\small\color{muted}<< e.period | tex >>}\par
<% if e.bullets %>
\begin{itemize}
<% for b in e.bullets %>\item << b | tex >>
<% endfor %>
\end{itemize}
<% endif %>
\vspace{4pt}
<% endfor %>
<% endif %>

<% if education %>
\section*{Education}
<% for e in education %>
{\bfseries\color{ink}<< e.title | tex >>}<% if e.subtitle %>, {\itshape << e.subtitle | tex >>}<% endif %>\hfill{\sansfont\small\color{muted}<< e.period | tex >>}\par
<% endfor %>
<% endif %>

<% if skills %>
\section*{Skills}
<% for s in skills %>
<% if s.label %>{\bfseries\color{ink}<< s.label | tex >>}\quad <% endif %>{\color{ink}<< s.value | tex >>}\par\vspace{2pt}
<% endfor %>
<% endif %>

<% if languages %>
\section*{Languages}
{\color{ink}<< languages | tex >>}
<% endif %>

<% for sec in other_sections %>
\section*{<< sec.title | tex >>}
<% if sec.content %>{\color{ink}<< sec.content | tex >>}<% endif %>
<% if sec.entries %>
<% for e in sec.entries %>
{\bfseries<< e.title | tex >>}\hfill{\sansfont\small\color{muted}<< e.period | tex >>}\par
<% if e.bullets %>\begin{itemize}<% for b in e.bullets %>\item << b | tex >><% endfor %>\end{itemize}<% endif %>
<% endfor %>
<% endif %>
<% endfor %>

\end{document}
