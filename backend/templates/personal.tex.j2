<# Personal (Boltach-inspired): framed photo left, name right, black date chips. #>
\documentclass[a4paper,11pt]{article}

\usepackage{fontspec}
\usepackage[a4paper,top=18mm,bottom=18mm,left=20mm,right=20mm]{geometry}
\usepackage{xcolor}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage{fontawesome5}
\usepackage[hidelinks]{hyperref}
\usepackage{etoolbox}
\usepackage{graphicx}
\usepackage{tabularx}

\setmainfont{DejaVu Sans}[Scale=0.92]

\definecolor{ink}{HTML}{1A1A1A}
\definecolor{muted}{HTML}{5A5A5A}
\definecolor{chipBg}{HTML}{1A1A1A}
\definecolor{chipFg}{HTML}{FFFFFF}
\definecolor{rule}{HTML}{C8C8C8}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\linespread{1.22}

\titleformat{\section}
  {\bfseries\large\color{ink}}
  {}{0pt}{\MakeUppercase}[\vspace{-2pt}\textcolor{ink}{\rule{\linewidth}{0.8pt}}]
\titlespacing*{\section}{0pt}{14pt}{6pt}

\setlist[itemize]{leftmargin=14pt,itemsep=1.5pt,topsep=2pt,parsep=0pt,label={\textbullet}}

\newcommand{\chip}[1]{\setlength{\fboxsep}{2.5pt}\colorbox{chipBg}{\color{chipFg}\small\,#1\,}}

% Personal-detail row: label | value, used for skills/personal-data style entries
\newcommand{\detailrow}[2]{%
  \noindent\hangindent=2em\hangafter=0
  \parbox{6.5em}{\itshape\color{muted}#1}\hspace{1.5em}#2\par\vspace{1pt}
}

% Entry row: heading + date chip on right, then subtitle + bullets
\newcommand{\personalentry}[5]{%
  \noindent{\bfseries\color{ink}#2}\hfill\ifstrempty{#1}{}{\chip{#1}}\par
  \ifstrempty{#3}{}{{\itshape\color{muted}#3}\par}
  \ifstrempty{#4}{}{{\small\color{muted}\faMapMarker*~#4}\par}
  \ifstrempty{#5}{}{\vspace{2pt}#5}\vspace{4pt}%
}

\begin{document}

% Header: photo + name + slogan
\noindent
<% if avatar_path %>
\begin{minipage}[c]{38mm}
\setlength{\fboxsep}{0pt}\setlength{\fboxrule}{1pt}%
\fbox{\includegraphics[width=36mm]{<< avatar_path >>}}
\end{minipage}\hfill
\begin{minipage}[c]{\dimexpr\linewidth-44mm\relax}
<% else %>
\begin{minipage}[c]{\linewidth}
<% endif %>
\raggedleft
<% if name %>{\bfseries\fontsize{30}{34}\selectfont\color{ink}<< name | tex >>}\par<% endif %>
<% if headline %>\vspace{2pt}{\Large\itshape\color{muted}<< headline | tex >>}\par<% endif %>
<% if salary_expectation %>\vspace{3pt}{\small\color{muted}<< salary_label | tex >>: << salary_expectation | tex >>}\par<% endif %>
\end{minipage}
\vspace{8pt}\par
\textcolor{rule}{\rule{\linewidth}{0.4pt}}

<% if emails or phones or links or other_contacts %>
\section*{<< labels.personal_details | tex >>}
<% for p in phones %>\detailrow{Phone}{\texttt{<< p | tex >>}}<% endfor %>
<% for e in emails %>\detailrow{Email}{\texttt{<< e | tex >>}}<% endfor %>
<% for l in links %>\detailrow{Link}{\texttt{<< l | tex >>}}<% endfor %>
<% for c in other_contacts %>\detailrow{Address}{<< c | tex >>}<% endfor %>
<% endif %>

<% if summary %>
\section*{<< labels.profile | tex >>}
{\color{ink}<< summary | tex >>}
<% endif %>

<% if experience %>
\section*{<< labels.experience | tex >>}
<% for e in experience %>
\personalentry{<< e.period | tex >>}{<< e.title | tex >>}{<< e.subtitle | tex >>}{<< e.location | tex >>}{%
<% if e.description %>{\small\color{muted}<< e.description | tex >>}\par<% endif %>%
<% if e.bullets %>\begin{itemize}<% for b in e.bullets %>\item << b | tex >><% endfor %>\end{itemize}<% endif %>%
}
<% endfor %>
<% endif %>

<% if projects %>
\section*{<< labels.projects | tex >>}
<% for e in projects %>
\personalentry{<< e.period | tex >>}{<< e.title | tex >>}{<< e.subtitle | tex >>}{<< e.location | tex >>}{%
<% if e.bullets %>\begin{itemize}<% for b in e.bullets %>\item << b | tex >><% endfor %>\end{itemize}<% endif %>%
}
<% endfor %>
<% endif %>

<% if education %>
\section*{<< labels.education | tex >>}
<% for e in education %>
\personalentry{<< e.period | tex >>}{<< e.title | tex >>}{<< e.subtitle | tex >>}{<< e.location | tex >>}{}
<% endfor %>
<% endif %>

<% if skills %>
\section*{<< labels.technical_skills | tex >>}
<% for s in skills %>
<% if s.label %>\detailrow{<< s.label | tex >>}{<< s.value | tex >>}<% else %>\noindent{\color{ink}<< s.value | tex >>}\par<% endif %>
<% endfor %>
<% endif %>

<% if languages %>
\section*{<< labels.languages | tex >>}
{\color{ink}<< languages | tex >>}
<% endif %>

<% for sec in other_sections %>
\section*{<< sec.title | tex >>}
<% if sec.content %>{\color{ink}<< sec.content | tex >>}<% endif %>
<% if sec.entries %>
<% for e in sec.entries %>
\personalentry{<< e.period | tex >>}{<< e.title | tex >>}{<< e.subtitle | tex >>}{<< e.location | tex >>}{%
<% if e.bullets %>\begin{itemize}<% for b in e.bullets %>\item << b | tex >><% endfor %>\end{itemize}<% endif %>%
}
<% endfor %>
<% endif %>
<% endfor %>

\end{document}
